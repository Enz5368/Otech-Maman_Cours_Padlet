# Copier ce fichier en .env sur le NAS. Ne jamais committer le fichier .env réel.
POSTGRES_DB=monespaceprof
POSTGRES_USER=monespaceprof
POSTGRES_PASSWORD=remplacer-par-un-secret-long

POSTGRES_DATA_PATH=/mnt/DriveMaison/Database/postgres
REDIS_DATA_PATH=/mnt/DriveMaison/Database/redis
USERS_DATA_PATH=/mnt/DriveMaison/Users
BACKUPS_DATA_PATH=/mnt/DriveMaison/Backups
LOGS_DATA_PATH=/mnt/DriveMaison/Logs
LOCAL_HTTP_PORT=30080

# À définir uniquement au premier démarrage, puis à retirer après création du compte.
INITIAL_ROSE_PASSWORD=
DEFAULT_QUOTA_BYTES=10737418240
MAX_UPLOAD_BYTES=536870912
TRUSTED_PROXY_IPS=*

# Récupération de mot de passe (secrets à fournir sur le NAS uniquement).
MEP_PUBLIC_BASE_URL=https://monespaceprof.com
MEP_SMTP_HOST=
MEP_SMTP_PORT=587
MEP_SMTP_USERNAME=
MEP_SMTP_PASSWORD=
MEP_SMTP_FROM=
MEP_SMTP_STARTTLS=true
