generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Class {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String
  order       Int        @default(0)
  status      String     @default("AVAILABLE")
  isPublished Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  sequences   Sequence[]
  resources   Resource[]
}

model Sequence {
  id          String    @id @default(cuid())
  title       String
  slug        String
  description String
  order       Int       @default(0)
  status      String    @default("AVAILABLE")
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  classId     String
  class       Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  sessions    Session[]
  resources   Resource[]

  @@unique([classId, slug])
}

model Session {
  id          String     @id @default(cuid())
  title       String
  slug        String
  description String
  order       Int        @default(0)
  status      String     @default("AVAILABLE")
  isPublished Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  sequenceId  String
  sequence    Sequence   @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  activities  Activity[]
  resources   Resource[]

  @@unique([sequenceId, slug])
}

model Activity {
  id            String     @id @default(cuid())
  title         String
  slug          String
  description   String
  instruction   String     @default("")
  text          String     @default("")
  order         Int        @default(0)
  status        String     @default("AVAILABLE")
  isPublished   Boolean    @default(true)
  publishDate   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  sessionId     String
  session       Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  resources     Resource[]

  @@unique([sessionId, slug])
}

model Resource {
  id          String       @id @default(cuid())
  title       String
  slug        String
  description String
  order       Int          @default(0)
  status      String       @default("AVAILABLE")
  isPublished Boolean      @default(true)
  type        String
  url         String
  filename    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  activityId  String?
  activity    Activity?    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  classId     String?
  class       Class?       @relation(fields: [classId], references: [id], onDelete: Cascade)
  sequenceId  String?
  sequence    Sequence?    @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  sessionId   String?
  session     Session?     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model News {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  order       Int      @default(0)
  status      String   @default("AVAILABLE")
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
